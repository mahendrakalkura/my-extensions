{
  "action": {
    "default_title": "Take screenshot"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "optional": [],
        "required": ["none"]
      },
      "id": "my-extensions-1@mahendrakalkura"
    }
  },
  "content_scripts": [
    {
      "css": ["atlassian.css"],
      "matches": ["*://*.atlassian.net/*"],
      "run_at": "document_start"
    },
    {
      "css": ["imdb.css"],
      "matches": ["*://*.imdb.com/*"],
      "run_at": "document_start"
    }
  ],
  "description": "Screenshot any element, expand content, and summarize pages with AI services",
  "host_permissions": [
    "*://*.claude.ai/*",
    "*://*.deepseek.com/*",
    "*://*.openai.com/*",
    "*://*.qwen.ai/*",
    "*://chat.z.ai/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*"
  ],
  "manifest_version": 3,
  "name": "My Extensions",
  "permissions": ["activeTab", "scripting", "contextMenus", "storage", "tabs"],
  "version": "1.5"
}
